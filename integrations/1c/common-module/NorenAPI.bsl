// Общий модуль NorenAPI (Сервер, Вызов сервера)
// Настройки храните в регистре сведений NorenНастройки или константах.

#Область ПрограммныйИнтерфейс

Функция СоздатьИнвойс(НомерЗаказа, Сумма, Валюта = "USD") Экспорт
	
	Настройки = ПолучитьНастройки();
	
	Тело = Новый Структура;
	Тело.Вставить("project_id", Настройки.ProjectId);
	Тело.Вставить("merchant_order_id", "1c-" + Строка(НомерЗаказа));
	Тело.Вставить("amount_fiat", Формат(Сумма, "ЧГ=0; ЧД=2; ЧРД=.; ЧН=0"));
	Тело.Вставить("fiat_currency", Валюта);
	Тело.Вставить("crypto_currency", Настройки.Криптовалюта);
	Тело.Вставить("network", Настройки.Сеть);
	Тело.Вставить("metadata", Новый Структура("source", "1c-enterprise"));
	
	Ответ = ВыполнитьЗапросAPI("POST", "/invoices", Тело);
	Возврат Ответ;
	
КонецФункции

Функция СинхронизироватьИнвойс(InvoiceId) Экспорт
	Возврат ВыполнитьЗапросAPI("POST", "/invoices/" + InvoiceId + "/sync");
КонецФункции

Функция ПроверитьПодписьWebhook(Тело, ЗаголовокПодписи) Экспорт
	
	Секрет = ПолучитьНастройки().WebhookSecret;
	Если ПустаяСтрока(Секрет) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ПустаяСтрока(ЗаголовокПодписи) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Хеш = ПолучитьHexСтроку(
		ХешированиеДанных(ХешФункция.SHA256, Секрет + Тело) // см. реализацию HMAC ниже
	);
	
	// Платформа: X-Merset-Signature: sha256=<hex>
	// Используйте HMAC-SHA256(Секрет, Тело) — см. gitbook/webhooks.md
	Ожидаемая = "sha256=" + HMAC_SHA256(Секрет, Тело);
	Возврат Ожидаемая = ЗаголовокПодписи;
	
КонецФункции

Функция ЭтоОплаченныйСтатус(Статус) Экспорт
	Возврат Статус = "paid" ИЛИ Статус = "confirmed" ИЛИ Статус = "overpaid" ИЛИ Статус = "underpaid";
КонецФункции

Функция ЭтоОтмененныйСтатус(Статус) Экспорт
	Возврат Статус = "expired" ИЛИ Статус = "cancelled" ИЛИ Статус = "canceled" ИЛИ Статус = "failed";
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

Функция ПолучитьНастройки()
	
	// TODO: прочитать из вашего регистра сведений
	Настройки = Новый Структура;
	Настройки.Вставить("ApiBaseUrl", "https://api.noren.digital/api/v1/client");
	Настройки.Вставить("PublicKey", "");
	Настройки.Вставить("SecretKey", "");
	Настройки.Вставить("ProjectId", "");
	Настройки.Вставить("WebhookSecret", "");
	Настройки.Вставить("Криптовалюта", "USDT");
	Настройки.Вставить("Сеть", "TRC20");
	Возврат Настройки;
	
КонецФункции

Функция ВыполнитьЗапросAPI(Метод, Путь, Тело = Неопределено)
	
	Настройки = ПолучитьНастройки();
	Соединение = Новый HTTPСоединение(
		ИзвлечьХост(Настройки.ApiBaseUrl),
		443,
		,
		,
		,
		30,
		Новый ЗащищенноеСоединениеOpenSSL
	);
	
	Запрос = Новый HTTPЗапрос(Настройки.ApiBaseUrl + Путь);
	Запрос.Заголовки.Вставить("X-API-Key", Настройки.PublicKey);
	Запрос.Заголовки.Вставить("X-API-Secret", Настройки.SecretKey);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	
	Если Тело <> Неопределено Тогда
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку();
		ЗаписатьJSON(Запись, Тело);
		Запрос.УстановитьТелоИзСтроки(Запись.Закрыть());
	КонецЕсли;
	
	Если Метод = "POST" Тогда
		ОтветHTTP = Соединение.ОтправитьДляОбработки(Запрос);
	Иначе
		ОтветHTTP = Соединение.Получить(Запрос);
	КонецЕсли;
	
	Если ОтветHTTP.КодСостояния >= 400 Тогда
		ВызватьИсключение "Noren API HTTP " + ОтветHTTP.КодСостояния + ": " + ОтветHTTP.ПолучитьТелоКакСтроку();
	КонецЕсли;
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ОтветHTTP.ПолучитьТелоКакСтроку());
	Результат = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	Возврат Результат;
	
КонецФункции

