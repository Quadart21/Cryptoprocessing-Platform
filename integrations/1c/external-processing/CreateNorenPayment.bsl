// Обработка «Создать оплату Noren» для документа ЗаказКлиента / Реализация
// Вызов из формы: NorenAPI.СоздатьИнвойс(Объект.Номер, Объект.СуммаДокумента);

&НаКлиенте
Процедура СоздатьОплатуNoren(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПоказатьПредупреждение(, "Сначала запишите документ.");
		Возврат;
	КонецЕсли;
	
	URL = СоздатьОплатуNorenНаСервере();
	Если ЗначениеЗаполнено(URL) Тогда
		ЗапуститьПриложение(URL);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьОплатуNorenНаСервере()
	
	Инвойс = NorenAPI.СоздатьИнвойс(
		Объект.Номер,
		Объект.СуммаДокумента,
		"USD" // или валюта документа
	);
	
	URL = Инвойс.payment_page_url;
	NorenЗаказы.ЗафиксироватьИнвойс(Объект.Номер, Инвойс.id, URL);
	
	Возврат URL;
	
КонецФункции
