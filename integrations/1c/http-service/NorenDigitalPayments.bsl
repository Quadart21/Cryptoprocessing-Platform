// Модуль HTTP-сервиса NorenDigitalPayments
// Публикация: Администрирование → Публикация на веб-сервере → HTTP-сервис noren
//
// URL создания счёта: POST /noren/hs/v1/invoice
// URL webhook (принимает уведомления платформы): POST /noren/hs/v1/webhook

#Область ОбработчикиURL

Функция InvoiceCreate(Запрос)
	
	Тело = Запрос.ПолучитьТелоКакСтроку();
	Данные = ПрочитатьJSONВСтруктуру(Тело);
	
	Если Данные = Неопределено Тогда
		Возврат ОтветJSON(400, Новый Структура("error", "invalid_json"));
	КонецЕсли;
	
	Сумма = Данные.Сумма;
	НомерЗаказа = Данные.НомерЗаказа;
	Если НЕ ЗначениеЗаполнено(Сумма) ИЛИ НЕ ЗначениеЗаполнено(НомерЗаказа) Тогда
		Возврат ОтветJSON(400, Новый Структура("error", "amount_and_order_required"));
	КонецЕсли;
	
	Попытка
		Инвойс = NorenAPI.СоздатьИнвойс(
			Строка(НомерЗаказа),
			Сумма,
			?(Данные.Свойство("Валюта"), Данные.Валюта, "USD")
		);
	Исключение
		Возврат ОтветJSON(502, Новый Структура("error", ОписаниеОшибки()));
	КонецПопытки;
	
	// Сохранить связь заказ 1С ↔ invoice_id
	NorenЗаказы.ЗафиксироватьИнвойс(НомерЗаказа, Инвойс.id, Инвойс.payment_page_url);
	
	Возврат ОтветJSON(200, Инвойс);
	
КонецФункции

Функция WebhookReceive(Запрос)
	
	Тело = Запрос.ПолучитьТелоКакСтроку();
	Подпись = Запрос.Заголовки.Получить("X-Merset-Signature");
	
	Если НЕ NorenAPI.ПроверитьПодписьWebhook(Тело, Подпись) Тогда
		Возврат ОтветJSON(401, Новый Структура("error", "invalid_signature"));
	КонецЕсли;
	
	Данные = ПрочитатьJSONВСтруктуру(Тело);
	Если Данные = Неопределено Тогда
		Возврат ОтветJSON(400, Новый Структура("error", "invalid_json"));
	КонецЕсли;
	
	Событие = Данные.event;
	Если Событие = "webhook.test" Тогда
		Возврат ОтветJSON(200, Новый Структура("ok", Истина));
	КонецЕсли;
	
	Инвойс = Данные.invoice;
	Если Инвойс = Неопределено Тогда
		Возврат ОтветJSON(400, Новый Структура("error", "missing_invoice"));
	КонецЕсли;
	
	НомерЗаказа = NorenЗаказы.НомерЗаказаПоMerchantOrderId(Инвойс.merchant_order_id);
	Статус = НРег(Инвойс.status);
	
	Если NorenAPI.ЭтоОплаченныйСтатус(Статус) Тогда
		NorenЗаказы.ОтметитьОплату(НомерЗаказа, Инвойс.id);
	ИначеЕсли NorenAPI.ЭтоОтмененныйСтатус(Статус) Тогда
		NorenЗаказы.ОтметитьОтмену(НомерЗаказа, Статус);
	КонецЕсли;
	
	Возврат ОтветJSON(200, Новый Структура("ok", Истина));
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

Функция ОтветJSON(КодСостояния, Данные)
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Данные);
	Ответ.УстановитьТелоИзСтроки(Запись.Закрыть());
	Возврат Ответ;
	
КонецФункции

Функция ПрочитатьJSONВСтруктуру(СтрокаJSON)
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	Результат = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	Возврат Результат;
	
КонецФункции

#КонецОбласти
