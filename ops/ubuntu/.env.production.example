APP_NAME=CryptoProcessing Platform
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1
PUBLIC_API_BASE_URL=https://replace-with-your-domain.example
BACKEND_CORS_ORIGINS=https://replace-with-your-domain.example,https://www.replace-with-your-domain.example
SECURITY_FAIL_FAST=true
ALLOW_INSECURE_DEFAULTS_IN_LOCAL=false

SECRET_KEY=replace-with-random-64-char-secret
JWT_SECRET_KEY=replace-with-random-64-char-secret
FERNET_SECRET_KEY=replace-with-random-64-char-secret
WEBHOOK_SECRET_KEY=replace-with-random-64-char-secret

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cryptoprocessing
POSTGRES_USER=cryptoprocessing
POSTGRES_PASSWORD=replace-with-strong-db-password
# pg_dump: app user cannot bypass FORCE RLS; use backup_dump from setup-db.sh
BACKUP_PG_DUMP_USER=backup_dump
BACKUP_PG_DUMP_PASSWORD=replace-with-backup-dump-password

REDIS_URL=redis://127.0.0.1:6379/0

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=15000

CACHE_DEFAULT_TTL_SECONDS=30
CACHE_RATES_TTL_SECONDS=45
CACHE_PROVIDER_CURRENCIES_TTL_SECONDS=60
CACHE_ACCOUNTING_SUMMARY_TTL_SECONDS=20

SUPERADMIN_EMAIL=replace-with-admin@your-domain.example
SUPERADMIN_PASSWORD=replace-with-strong-password
SUPERADMIN_FULL_NAME=Platform Admin

PAYMENT_PROVIDER=mock
WEBHOOK_REQUIRE_SIGNATURE=true
WEBHOOK_ALLOW_LEGACY_PAYLOAD=false
WEBHOOK_ALLOW_LEGACY_SIGNATURE=false
WEBHOOK_MAX_SKEW_SECONDS=300
WEBHOOK_ALLOW_HTTP_IN_LOCAL=false

AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15
RATE_LIMIT_LOGIN_IP_PER_MINUTE=20
RATE_LIMIT_REGISTER_IP_PER_10M=8
RATE_LIMIT_INVOICE_IP_PER_MINUTE=120
RATE_LIMIT_INVOICE_AUTH_PER_MINUTE=90
RATE_LIMIT_READ_IP_PER_MINUTE=300
RATE_LIMIT_WEBHOOK_TEST_IP_PER_MINUTE=30
RATE_LIMIT_WEBHOOK_TEST_AUTH_PER_MINUTE=20
RATE_LIMIT_INTERNAL_WEBHOOK_IP_PER_MINUTE=240
RATE_LIMIT_OTP_PER_MINUTE=20

PROVIDER_HTTP_CONNECT_TIMEOUT_SECONDS=5
PROVIDER_HTTP_READ_TIMEOUT_SECONDS=20
PROVIDER_HTTP_POOL_CONNECTIONS=20
PROVIDER_HTTP_POOL_MAXSIZE=50
CLIENT_WEBHOOK_CONNECT_TIMEOUT_SECONDS=3
CLIENT_WEBHOOK_READ_TIMEOUT_SECONDS=10
CLIENT_WEBHOOK_POOL_CONNECTIONS=10
CLIENT_WEBHOOK_POOL_MAXSIZE=20

BACKUP_APP_DIR=/opt/cryptoprocessing
BACKUP_WORK_DIR=/opt/cryptoprocessing/var/backups
PG_DUMP_BIN=pg_dump

CRYPTO_CASH_API_BASE_URL=https://api.crypto-cash.world
CRYPTO_CASH_PUBLIC_KEY=
CRYPTO_CASH_SECRET_KEY=
